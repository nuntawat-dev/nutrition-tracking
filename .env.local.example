# Copy this file to `.env.local` and fill in the values.

# --- Required ---

# Your Anthropic API key (billing must be enabled). Server-side only.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# The single password used to log in to the app.
APP_PASSWORD=change-me-to-something-strong

# Secret used to encrypt the login cookie. MUST be at least 32 characters.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string-at-least-32-chars

# --- Database ---
# Local development uses a file DB by default (no config needed).
# For deployment (e.g. Vercel + Turso), set both of these:
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
